# ─── .env.example ─────────────────────────────────────────────────────────────
# Bu faylni nusxa ko'chirib .env nomli fayl yarating:
#   cp .env.example .env
# Keyin qiymatlarni to'ldiring.
# DIQQAT: .env faylini hech qachon git'ga push qilmang!

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# @BotFather dan olingan bot token
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Admin Telegram ID lari (vergul bilan ajrating, bo'shliqsiz)
# ID ni bilish uchun @userinfobot yoki @getmyid_bot dan foydalaning
ADMIN_IDS=123456789,987654321

# ─── Ma'lumotlar bazasi ───────────────────────────────────────────────────────
# SQLite (default, o'zgartirish shart emas)
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ─── Vaqt va rejalashtirish ───────────────────────────────────────────────────
# Vaqt zonasi (O'zbekiston uchun: Asia/Tashkent)
TIMEZONE=Asia/Tashkent

# Xabar yuborish soati (24-soatlik format)
SEND_HOUR=20
SEND_MINUTE=0

# ─── Web server (keep-alive) ──────────────────────────────────────────────────
# Render/Koyeb bu o'zgaruvchini avtomatik o'rnatadi
# Lokal testda qo'lda belgilash mumkin
PORT=8080

# Secret fayllar
# Bu JSON fayllarni repoga qo'shmang. Namuna uchun *.example.json dan nusxa oling.
STUDENT_CREDENTIALS_FILE=student_credentials.json
CURATORS_FILE=curators.json

# Alternativ variant: JSON'ni to'g'ridan-to'g'ri env orqali berish
# STUDENT_CREDENTIALS_JSON={"1342455":{"name":"Ali","password":"12345","group":"nF-2506"}}
# CURATORS_JSON={"diyora":{"password":"secret","full_name":"Diyora","telegram_username":"@diyora"}}
