{
  "name": "otaonabot",
  "version": "1.0.0",
  "description": "E2E tests (Playwright) for Telegram Mini App static pages",
  "private": true,
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "bash scripts/run-ci.sh",
    "test:ci": "bash scripts/run-ci.sh",
    "test:e2e": "playwright test",
    "test:qa": "playwright test",
    "test:e2e:student": "playwright test e2e-tests/student.spec.js",
    "test:e2e:core": "playwright test e2e-tests/student.spec.js e2e-tests/admin-mini.functional.spec.js",
    "test:e2e:audit": "playwright test e2e-tests/audit-student-admin.spec.js",
    "test:e2e:audit:headed": "playwright test e2e-tests/audit-student-admin.spec.js --headed",
    "test:e2e:audit:trace": "playwright test e2e-tests/audit-student-admin.spec.js --trace on",
    "test:qa:senior": "playwright test e2e-tests/qa-senior-audit.spec.js e2e-tests/audit-student-admin.spec.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SUNNATBEE/eslatma.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SUNNATBEE/eslatma/issues"
  },
  "homepage": "https://github.com/SUNNATBEE/eslatma#readme",
  "dependencies": {
    "@playwright/test": "^1.59.1"
  }
}
