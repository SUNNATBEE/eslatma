# ── Binary / runtime files ─────────────────────────────────────────
bot.db
*.sqlite
*.log
bot_start.log

# ── Python cache ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Environment / secrets ──────────────────────────────────────────
